---
/* Schaubild zu Sektion "Datenfluss":
   Vier Ebenen — Business Central oben, BFF als Vermittler darunter,
   dann der bc-client, schließlich die vier Apps. Eine zusätzliche
   Messaging-Schleife verbindet die Zentrale mit den drei mobilen Apps. */
---

<figure class="mt-10">
  <div class="overflow-x-auto rounded-xl border border-line/70 bg-surface-alt p-6 shadow-card dark:shadow-card-dark">
    <svg
      viewBox="0 0 820 500"
      role="img"
      aria-labelledby="dataflow-title dataflow-desc"
      class="mx-auto block h-auto w-full min-w-[680px] max-w-[780px]"
    >
      <title id="dataflow-title">Datenfluss zwischen Apps, bc-client, BFF und Business Central</title>
      <desc id="dataflow-desc">
        Business Central liefert Daten über das BFF und den bc-client an die
        vier Apps. Das BFF prüft Sitzung und Berechtigung, bevor es Anfragen
        an Business Central weiterreicht. Die Zentrale kommuniziert
        zusätzlich über den Messaging-Kanal direkt mit den drei mobilen
        Apps.
      </desc>

      <!-- Pfeilspitzen-Definitionen -->
      <defs>
        <marker id="df-arrow" viewBox="0 0 10 10" refX="9" refY="5"
          markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="rgb(var(--color-ink-subtle))" />
        </marker>
        <marker id="df-arrow-msg" viewBox="0 0 10 10" refX="9" refY="5"
          markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="rgb(var(--color-tech))" />
        </marker>
      </defs>

      <!-- Ebene 1: Business Central -->
      <g>
        <rect x="280" y="20" width="260" height="60" rx="10"
          fill="rgb(var(--color-accent) / 0.07)"
          stroke="rgb(var(--color-accent))" stroke-width="1.5" />
        <text x="410" y="45" text-anchor="middle"
          fill="rgb(var(--color-accent))"
          font-size="10" font-weight="600" letter-spacing="1.5">ERP</text>
        <text x="410" y="68" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="16" font-weight="600">Business Central</text>
      </g>

      <!-- Verbindung BC ↔ BFF -->
      <g>
        <line x1="410" y1="80" x2="410" y2="115"
          stroke="rgb(var(--color-ink-subtle))" stroke-width="1.5"
          marker-start="url(#df-arrow)" marker-end="url(#df-arrow)" />
        <text x="430" y="102"
          fill="rgb(var(--color-ink-muted))" font-size="11">OData · intern</text>
      </g>

      <!-- Ebene 2: BFF -->
      <g>
        <rect x="270" y="120" width="280" height="78" rx="10"
          fill="rgb(var(--color-tech) / 0.08)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5" />
        <text x="410" y="142" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="10" font-weight="600" letter-spacing="1.5">VERMITTLERDIENST</text>
        <text x="410" y="165" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="15" font-weight="600">BFF — Backend for Frontend</text>
        <text x="410" y="184" text-anchor="middle"
          fill="rgb(var(--color-ink-muted))"
          font-size="11">Session-Prüfung · Berechtigungs-Check</text>
      </g>

      <!-- Verbindung BFF ↔ bc-client -->
      <g>
        <line x1="410" y1="198" x2="410" y2="235"
          stroke="rgb(var(--color-ink-subtle))" stroke-width="1.5"
          marker-start="url(#df-arrow)" marker-end="url(#df-arrow)" />
        <text x="430" y="221"
          fill="rgb(var(--color-ink-muted))" font-size="11">HTTPS · HttpOnly-Cookie</text>
      </g>

      <!-- Ebene 3: bc-client -->
      <g>
        <rect x="300" y="240" width="220" height="58" rx="8"
          fill="rgb(var(--color-surface))"
          stroke="rgb(var(--color-line))" stroke-width="1.5" />
        <text x="410" y="262" text-anchor="middle"
          fill="rgb(var(--color-ink-subtle))"
          font-size="10" font-weight="600" letter-spacing="1.5">PACKAGE</text>
        <text x="410" y="283" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="15" font-weight="600">bc-client</text>
      </g>

      <!-- Verteiler-Linien von bc-client zu Apps -->
      <g stroke="rgb(var(--color-ink-subtle))" stroke-width="1.5" fill="none">
        <path d="M 410 298 L 410 318 L 120 318 L 120 348"
          marker-end="url(#df-arrow)" />
        <path d="M 410 298 L 410 318 L 290 318 L 290 348"
          marker-end="url(#df-arrow)" />
        <path d="M 410 298 L 410 318 L 530 318 L 530 348"
          marker-end="url(#df-arrow)" />
        <path d="M 410 298 L 410 318 L 700 318 L 700 348"
          marker-end="url(#df-arrow)" />
      </g>

      <!-- Ebene 4: Vier Apps -->
      <g>
        <rect x="55" y="348" width="130" height="60" rx="8"
          fill="rgb(var(--color-tech) / 0.08)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5" />
        <text x="120" y="373" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="9" font-weight="600" letter-spacing="1.5">MOBIL</text>
        <text x="120" y="393" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="14" font-weight="600">Scanner</text>

        <rect x="225" y="348" width="130" height="60" rx="8"
          fill="rgb(var(--color-tech) / 0.08)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5" />
        <text x="290" y="373" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="9" font-weight="600" letter-spacing="1.5">MOBIL</text>
        <text x="290" y="393" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="14" font-weight="600">Außendienst</text>

        <rect x="465" y="348" width="130" height="60" rx="8"
          fill="rgb(var(--color-tech) / 0.08)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5" />
        <text x="530" y="373" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="9" font-weight="600" letter-spacing="1.5">MOBIL</text>
        <text x="530" y="393" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="14" font-weight="600">Auslieferung</text>

        <rect x="635" y="348" width="130" height="60" rx="8"
          fill="rgb(var(--color-tech) / 0.14)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5" />
        <text x="700" y="373" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="9" font-weight="600" letter-spacing="1.5">BÜRO</text>
        <text x="700" y="393" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="14" font-weight="600">Zentrale</text>
      </g>

      <!-- Messaging-Schleife zwischen Zentrale und mobilen Apps -->
      <g>
        <path d="M 700 408 L 700 450 L 120 450 L 120 408"
          fill="none"
          stroke="rgb(var(--color-tech))" stroke-width="1.5"
          stroke-dasharray="6 4"
          marker-start="url(#df-arrow-msg)"
          marker-end="url(#df-arrow-msg)" />
        <path d="M 290 450 L 290 408"
          fill="none"
          stroke="rgb(var(--color-tech))" stroke-width="1.5"
          stroke-dasharray="6 4"
          marker-end="url(#df-arrow-msg)" />
        <path d="M 530 450 L 530 408"
          fill="none"
          stroke="rgb(var(--color-tech))" stroke-width="1.5"
          stroke-dasharray="6 4"
          marker-end="url(#df-arrow-msg)" />

        <rect x="320" y="462" width="180" height="28" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-tech))" stroke-width="1" />
        <text x="410" y="480" text-anchor="middle"
          fill="rgb(var(--color-tech))" font-size="11" font-weight="600">
          messaging (Echtzeit)
        </text>
      </g>
    </svg>
  </div>
  <figcaption class="mt-3 text-sm leading-relaxed text-ink-subtle">
    Schaubild&nbsp;3 — Daten laufen über den bc-client zum BFF, dort
    werden Sitzung und Berechtigung geprüft, und erst dann reicht das BFF
    die Anfrage an Business Central weiter. Die Zentrale tauscht zusätzlich
    Echtzeit-Nachrichten mit den mobilen Apps aus.
  </figcaption>
</figure>
