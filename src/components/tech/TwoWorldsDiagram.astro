---
/* Schaubild zu Sektion "Zwei getrennte Welten":
   Links Business Central (BC-Teal), in der Mitte das BFF als
   schmale Vermittlerschicht (Tech-Slate), rechts die App-Landschaft.
   So wird auf einen Blick sichtbar, dass die Apps niemals direkt
   mit BC sprechen. */
---

<figure class="mt-10">
  <div class="overflow-x-auto rounded-xl border border-line/70 bg-surface-alt p-6 shadow-card dark:shadow-card-dark">
    <svg
      viewBox="0 0 960 320"
      role="img"
      aria-labelledby="two-worlds-title two-worlds-desc"
      class="mx-auto block h-auto w-full min-w-[720px] max-w-[900px]"
    >
      <title id="two-worlds-title">Die zwei Welten der Roadmap mit BFF als Vermittler</title>
      <desc id="two-worlds-desc">
        Business Central auf der linken Seite und die App-Landschaft auf der
        rechten Seite. In der Mitte sitzt das BFF als schmale
        Vermittlerschicht zwischen beiden Welten. Die Apps sprechen
        ausschließlich mit dem BFF, nicht direkt mit Business Central.
      </desc>

      <!-- Linke Welt: Business Central -->
      <g>
        <rect
          x="30" y="30" width="290" height="260" rx="14"
          fill="rgb(var(--color-accent) / 0.07)"
          stroke="rgb(var(--color-accent))" stroke-width="1.5"
        />
        <text x="175" y="64" text-anchor="middle"
          fill="rgb(var(--color-accent))"
          font-size="11" font-weight="600" letter-spacing="2">WELT 1</text>
        <text x="175" y="100" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="20" font-weight="600">Business Central</text>
        <text x="175" y="122" text-anchor="middle"
          fill="rgb(var(--color-ink-muted))"
          font-size="12">Das ERP von Optimo</text>

        <rect x="70" y="148" width="210" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="175" y="172" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="13">BC-Standard (Säule 1)</text>

        <rect x="70" y="198" width="210" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="175" y="222" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="13">Etiketten-Modul (Säule 5)</text>

        <text x="175" y="266" text-anchor="middle"
          fill="rgb(var(--color-ink-subtle))" font-size="11">
          Programmiersprache AL · läuft auf dem BC-Server
        </text>
      </g>

      <!-- Verbindung BC ↔ BFF -->
      <g>
        <line x1="320" y1="160" x2="360" y2="160"
          stroke="rgb(var(--color-ink-subtle))" stroke-width="1.5"
          stroke-dasharray="5 4" />
        <polygon points="328,160 338,154 338,166" fill="rgb(var(--color-ink-subtle))" />
        <polygon points="352,160 342,154 342,166" fill="rgb(var(--color-ink-subtle))" />
      </g>

      <!-- Mitte: BFF als Vermittlerschicht -->
      <g>
        <rect
          x="360" y="95" width="200" height="130" rx="12"
          fill="rgb(var(--color-tech) / 0.05)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5"
          stroke-dasharray="0"
        />
        <text x="460" y="118" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="10" font-weight="600" letter-spacing="2">VERMITTLER</text>
        <text x="460" y="145" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="18" font-weight="600">BFF</text>
        <text x="460" y="164" text-anchor="middle"
          fill="rgb(var(--color-ink-muted))"
          font-size="11">Backend for Frontend</text>

        <rect x="378" y="178" width="164" height="28" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="460" y="197" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="11">LDAP-Auth · BC-Proxy</text>
      </g>

      <!-- Verbindung BFF ↔ Apps -->
      <g>
        <line x1="560" y1="160" x2="600" y2="160"
          stroke="rgb(var(--color-ink-subtle))" stroke-width="1.5"
          stroke-dasharray="5 4" />
        <polygon points="568,160 578,154 578,166" fill="rgb(var(--color-ink-subtle))" />
        <polygon points="592,160 582,154 582,166" fill="rgb(var(--color-ink-subtle))" />
      </g>

      <!-- Rechte Welt: App-Landschaft -->
      <g>
        <rect
          x="600" y="30" width="290" height="260" rx="14"
          fill="rgb(var(--color-tech) / 0.07)"
          stroke="rgb(var(--color-tech))" stroke-width="1.5"
        />
        <text x="745" y="64" text-anchor="middle"
          fill="rgb(var(--color-tech))"
          font-size="11" font-weight="600" letter-spacing="2">WELT 2</text>
        <text x="745" y="100" text-anchor="middle"
          fill="rgb(var(--color-ink))"
          font-size="20" font-weight="600">App-Landschaft</text>
        <text x="745" y="122" text-anchor="middle"
          fill="rgb(var(--color-ink-muted))"
          font-size="12">Die vier PITapp-Apps</text>

        <rect x="630" y="148" width="100" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="680" y="172" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="12">Scanner</text>

        <rect x="760" y="148" width="100" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="810" y="172" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="12">Außendienst</text>

        <rect x="630" y="198" width="100" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="680" y="222" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="12">Auslieferung</text>

        <rect x="760" y="198" width="100" height="38" rx="6"
          fill="rgb(var(--color-surface-alt))"
          stroke="rgb(var(--color-line))" />
        <text x="810" y="222" text-anchor="middle"
          fill="rgb(var(--color-ink))" font-size="12">Zentrale</text>

        <text x="745" y="266" text-anchor="middle"
          fill="rgb(var(--color-ink-subtle))" font-size="11">
          TypeScript · React · läuft auf Endgeräten
        </text>
      </g>
    </svg>
  </div>
  <figcaption class="mt-3 text-sm leading-relaxed text-ink-subtle">
    Schaubild&nbsp;1 — Zwei klar getrennte Code-Welten, verbunden über das
    BFF als schmale Vermittlerschicht. Die Apps kommunizieren ausschließlich
    mit dem BFF.
  </figcaption>
</figure>
